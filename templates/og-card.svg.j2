<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#0b1020"/>
      <stop offset="1" stop-color="#1a2340"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <text x="80" y="120" font-family="Inter, system-ui, sans-serif" font-size="28" fill="#7aa6ff" font-weight="600" letter-spacing="2">{{ site_title|upper }}</text>
  <text x="80" y="240" font-family="Inter, system-ui, sans-serif" font-size="76" fill="#ffffff" font-weight="800">{{ name }}</text>
  <text x="80" y="300" font-family="Inter, system-ui, sans-serif" font-size="28" fill="#9fb4d9">{{ category_name }}</text>
  <foreignObject x="80" y="340" width="1040" height="200">
    <div xmlns="http://www.w3.org/1999/xhtml" style="font-family: Inter, system-ui, sans-serif; font-size: 32px; line-height: 1.35; color: #e8eefc;">{{ summary }}</div>
  </foreignObject>
  <text x="80" y="580" font-family="Inter, system-ui, sans-serif" font-size="22" fill="#7aa6ff">Verified {{ last_verified }}</text>
  <text x="1120" y="580" text-anchor="end" font-family="Inter, system-ui, sans-serif" font-size="22" fill="#7aa6ff">{{ base_url }}</text>
</svg>
