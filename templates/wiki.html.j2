<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ site.title }}</title>
<meta name="description" content="{{ site.tagline }}">
<link rel="canonical" href="{{ site.base_url }}">
<meta property="og:title" content="{{ site.title }}">
<meta property="og:description" content="{{ site.tagline }}">
<meta property="og:url" content="{{ site.base_url }}">
<meta property="og:type" content="website">
<meta property="og:image" content="{{ site.base_url }}static/og/index.png">
<meta name="twitter:card" content="summary_large_image">
<link rel="alternate" type="application/rss+xml" title="{{ site.title }} — Recently Added" href="{{ site.base_url }}feed.xml">
<link rel="stylesheet" href="static/style.css">
</head>
<body>
<header class="hero">
  <div class="hero-inner">
    <h1>{{ site.title }}</h1>
    <p class="tagline">{{ site.tagline }}</p>
    <p class="meta">
      <span>Last curated: <time datetime="{{ generated_at }}">{{ generated_at_human }}</time></span>
      <span>·</span>
      <span>{{ entries|length }} entries across {{ categories|length }} categories</span>
      <span>·</span>
      <a href="{{ site.repo_url }}">GitHub</a>
      <span>·</span>
      <a href="feed.xml">RSS</a>
      <span>·</span>
      <a href="{{ site.repo_url }}/issues/new?title=Suggest:+&labels=suggestion">Suggest a tool</a>
    </p>
  </div>
</header>

<main>
  <aside class="toc">
    <h2>Categories</h2>
    <ul>
      {% for cat in categories %}
      <li><a href="#{{ cat.id }}">{{ cat.name }} <span class="count">{{ counts[cat.id] }}</span></a></li>
      {% endfor %}
    </ul>
    <h2>Recently added</h2>
    <ul class="recent">
      {% for e in recent %}
      <li><a href="#{{ e.id }}">{{ e.name }}</a> <span class="date">{{ e.added }}</span></li>
      {% endfor %}
    </ul>
  </aside>

  <section class="content">
    {% for cat in categories %}
    <section class="category" id="{{ cat.id }}">
      <h2>{{ cat.name }}</h2>
      <p class="cat-blurb">{{ cat.blurb }}</p>
      <div class="cards">
        {% for e in by_category[cat.id] %}
        <article class="card" id="{{ e.id }}">
          <header class="card-head">
            <h3><a href="{{ e.url }}" rel="noopener">{{ e.name }}</a></h3>
            <span class="verified" title="Last verified">✓ {{ e.last_verified }}</span>
          </header>
          <p class="summary">{{ e.summary }}</p>
          <p class="why"><strong>Why it matters.</strong> {{ e.why_it_matters }}</p>
          <footer class="card-foot">
            <a class="btn" href="{{ e.url }}" rel="noopener">Open ↗</a>
            <button class="btn copy" data-link="{{ site.base_url }}#{{ e.id }}">Copy link</button>
            <a class="btn" href="https://twitter.com/intent/tweet?text={{ e.name|urlencode }}%20%E2%80%94%20{{ e.summary|urlencode }}&url={{ (site.base_url ~ '#' ~ e.id)|urlencode }}" target="_blank" rel="noopener">Share</a>
          </footer>
        </article>
        {% endfor %}
      </div>
    </section>
    {% endfor %}
  </section>
</main>

<footer class="site-foot">
  <p>Curated daily by an AI agent. Every entry is verified live before it lands here.</p>
  <p>Source on <a href="{{ site.repo_url }}">GitHub</a> — PRs and issues welcome.</p>
</footer>

<script src="static/app.js" defer></script>
</body>
</html>
